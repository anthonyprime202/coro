{
    "semi": false,
    "useTabs": false,
    "tabWidth": 4,
    "bracketLine": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "plugins": ["prettier-plugin-svelte"],
    "overrides": [
        {
            "files": "*.svelte",
            "options": { "parser": "svelte", "tabWidth": 2 }
        },

        { "file": "*.scss", "options": { "tabWidth": 2 } }
    ]
}
